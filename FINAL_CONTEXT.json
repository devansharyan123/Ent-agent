  "api_endpoints": {
    "POST /register": {
      "request": {"username", "email", "password", "role: admin|hr|employee"},
      "response": {"message", "user_id"},
      "purpose": "Create new user account"
    },
    "POST /login": {
      "request": {"username", "password"},
      "response": {"message", "user_id", "role"},
      "purpose": "Authenticate user"
    },
    "POST /ask": {
      "request": {"user_id", "question", "conversation_id (optional)"},
      "response": {"status", "message_id", "conversation_id", "answer", "sources", "sequence_no"},
      "purpose": "Main endpoint - ask agent question"
    },
    "GET /conversation/{id}": {
      "response": {"status", "conversation_id", "messages", "total_messages"},
      "purpose": "Retrieve conversation history"
    },
    "GET /documents": {
      "query_params": "user_id",
      "response": {"status", "documents", "total_documents", "user_role"},
      "purpose": "List accessible documents for user"
    }
  },

  "rag_pipeline": {
    "step_1": "Role Validation → get_allowed_categories(user_role)",
    "step_2": "Query Embedding → get_embedder().encode(query)",
    "step_3": "RBAC Vector Search → pgvector with WHERE category = ANY(...)",
    "step_4": "LLM Grounding → ChatGroq(temperature=0.0)",
    "step_5": "Response Construction → {answer, sources, retrieved_chunks}",
    "step_6": "Tool Logging → INSERT INTO app.tool_logs"
  },

